# AI Agent System Backend Environment Variables
# Copy this file to .env. Never commit the populated .env file.

# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=true
HOST=127.0.0.1
PORT=5000

# Generate independent secrets, for example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES=3600

# Database
DATABASE_URL=sqlite:///ai_agent_system.db

# Browser access. Use a comma-separated allowlist; never use * in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_SUPPORTS_CREDENTIALS=false

# Account and development-data controls
ALLOW_PUBLIC_REGISTRATION=false
ALLOW_DEMO_DATA=false
DEMO_ADMIN_PASSWORD=
DEMO_USER_PASSWORD=

# Optional AI provider
OPENAI_API_KEY=

# Optional Telegram integration. Configure both values or leave both blank.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
